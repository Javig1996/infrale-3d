# ============================================================
# INFRALE 3D — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ============================================================

# --- Supabase ---
# Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# --- Cloudflare R2 (modelos IFC) ---
# Cloudflare Dashboard > R2 > Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=tu_account_id
CLOUDFLARE_R2_BUCKET=infrale-ifc-models
CLOUDFLARE_R2_ACCESS_KEY_ID=tu_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=tu_secret_key
# URL pública del bucket (opcional, si habilitas dominio personalizado en R2)
CLOUDFLARE_R2_PUBLIC_URL=https://pub-XXXXXXXX.r2.dev

# --- Resend (alertas email) ---
# resend.com > API Keys
RESEND_API_KEY=re_XXXXXXXXXX
RESEND_FROM_EMAIL=alertas@infrale3d.com

# --- Seguridad Cron ---
# Genera un string aleatorio seguro: openssl rand -hex 32
CRON_SECRET=cambia_esto_por_un_string_aleatorio_seguro

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
